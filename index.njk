<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Nick Rosado · Enlightenment Educator</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Cormorant+SC:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #f0ebe0;
  --warm:  #faf7f2;
  --ink:   #16110d;
  --char:  #2b2118;
  --gold:  #c49220;
  --gold2: #e4b440;
  --red:   #891b1b;
  --red2:  #6c1010;
  --mute:  #7a6e60;
  --rule:  #d0c4b0;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { font-size:16px; scroll-behavior:smooth; }
body { background:var(--cream); color:var(--ink); font-family:"EB Garamond",Georgia,serif; min-width:1280px; overflow-x:hidden; }

/* ── NAV ── */
nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  height:58px; display:flex; align-items:center; justify-content:space-between;
  padding:0 56px;
  background:rgba(240,235,224,0.97); backdrop-filter:blur(8px);
  border-bottom:1px solid var(--rule);
}
.nav-logo { font-family:"Cormorant SC",serif; font-size:.76rem; letter-spacing:.2em; color:var(--char); text-decoration:none; }
.nav-links { display:flex; gap:38px; list-style:none; }
.nav-links a { font-family:"Cormorant SC",serif; font-size:.7rem; letter-spacing:.15em; color:var(--mute); text-decoration:none; transition:color .2s; }
.nav-links a:hover { color:var(--red); }
.nav-cta a { font-family:"Cormorant SC",serif; font-size:.7rem; letter-spacing:.15em; background:var(--ink); color:var(--warm); padding:9px 22px; text-decoration:none; transition:background .2s; }
.nav-cta a:hover { background:var(--red); }

/* ── S1: HERO ── */
.hero { display:grid; grid-template-columns:1fr 1fr; min-height:100vh; padding-top:58px; }

.hero-l {
  padding:88px 80px 88px 72px;
  display:flex; flex-direction:column; justify-content:center;
  background:var(--cream);
}
.hero-eyebrow { font-family:"Cormorant SC",serif; font-size:.68rem; letter-spacing:.28em; color:var(--gold); margin-bottom:30px; }
.hero-hed {
  font-family:"Cormorant Garamond",serif;
  font-size:84px; font-weight:400; line-height:1.02;
  color:var(--ink); margin-bottom:30px;
}
.hero-hed em { font-style:italic; color:var(--red); }
.hero-sub { font-size:1.2rem; line-height:1.75; color:var(--char); max-width:44ch; margin-bottom:48px; }
.hero-btns { display:flex; gap:14px; }
.btn-dark { font-family:"Cormorant SC",serif; font-size:.72rem; letter-spacing:.14em; background:var(--ink); color:var(--warm); padding:13px 28px; text-decoration:none; transition:background .2s; display:inline-block; }
.btn-dark:hover { background:var(--red); }
.btn-outline { font-family:"Cormorant SC",serif; font-size:.72rem; letter-spacing:.14em; border:1px solid var(--rule); color:var(--ink); padding:13px 28px; text-decoration:none; transition:border-color .2s,background .2s; display:inline-block; }
.btn-outline:hover { border-color:var(--mute); background:rgba(0,0,0,.03); }

/* hero right: 2x2 poet portraits */
.hero-r { display:grid; grid-template-columns:1fr 1fr; grid-template-rows:1fr 1fr; overflow:hidden; }
.poet-cell { position:relative; overflow:hidden; cursor:default; }
.poet-cell img { width:100%; height:100%; object-fit:cover; object-position:center 20%; display:block; filter:grayscale(15%) brightness(.9); transition:transform .5s ease, filter .4s ease; }
.poet-cell:hover img { transform:scale(1.06); filter:grayscale(0%) brightness(1); }
.poet-label {
  position:absolute; bottom:0; left:0; right:0;
  padding:40px 18px 14px;
  background:linear-gradient(to top, rgba(22,17,13,.75) 0%, transparent 100%);
  font-family:"Cormorant SC",serif; font-size:.62rem; letter-spacing:.22em; color:rgba(240,235,224,.9);
}

/* ── S2: ABOUT ── */
.about { display:grid; grid-template-columns:50% 50%; min-height:680px; background:var(--warm); }
.about-l { padding:100px 80px; display:flex; flex-direction:column; justify-content:center; border-right:1px solid var(--rule); }
.sec-tag { font-family:"Cormorant SC",serif; font-size:.66rem; letter-spacing:.26em; color:var(--gold); margin-bottom:20px; display:flex; align-items:center; gap:12px; }
.sec-tag::after { content:""; display:block; width:36px; height:1px; background:var(--gold); }
.about-hed { font-family:"Cormorant Garamond",serif; font-size:66px; font-weight:400; line-height:1.05; margin-bottom:32px; }
.about-hed em { font-style:italic; color:var(--red); }
.about-body { font-size:1.16rem; line-height:1.8; color:var(--char); margin-bottom:22px; }
.about-pull { border-left:3px solid var(--gold); padding-left:22px; margin:28px 0; font-family:"Cormorant Garamond",serif; font-size:1.32rem; font-style:italic; line-height:1.5; color:var(--char); }
.btn-get { font-family:"Cormorant SC",serif; font-size:.72rem; letter-spacing:.14em; background:var(--ink); color:var(--warm); padding:13px 36px; text-decoration:none; display:inline-block; margin-top:8px; transition:background .2s; }
.btn-get:hover { background:var(--red); }
.about-r { overflow:hidden; }
.about-r img { width:100%; height:100%; object-fit:cover; object-position:center 15%; display:block; }

/* ── S3: COURSES ── */
.courses { padding:100px 60px; background:var(--cream); }
.courses-header { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:56px; }
.courses-hed { font-family:"Cormorant Garamond",serif; font-size:76px; font-weight:400; line-height:1.0; }
.courses-hed em { font-style:italic; color:var(--red); }
.courses-grid { display:grid; grid-template-columns:repeat(4,1fr); border:1px solid var(--rule); }
.card { border-right:1px solid var(--rule); display:flex; flex-direction:column; background:var(--warm); }
.card:last-child { border-right:none; }
.card-img-wrap { position:relative; overflow:hidden; aspect-ratio:3/4; }
.card-img-wrap img { width:100%; height:100%; object-fit:cover; display:block; transition:transform .45s ease; }
.card:hover .card-img-wrap img { transform:scale(1.05); }
.badge { position:absolute; top:14px; left:14px; z-index:2; font-family:"Cormorant SC",serif; font-size:.58rem; letter-spacing:.16em; padding:5px 10px; color:var(--warm); }
.badge-red { background:var(--red); }
.badge-blue { background:#2a4a80; }
.badge-dk { background:#3a3028; }
.card-body { padding:24px 24px 28px; flex:1; display:flex; flex-direction:column; border-top:1px solid var(--rule); }
.card-poet { font-family:"Cormorant SC",serif; font-size:.6rem; letter-spacing:.18em; color:var(--gold); margin-bottom:6px; }
.card-title { font-family:"Cormorant Garamond",serif; font-size:1.55rem; font-weight:400; line-height:1.1; margin-bottom:10px; }
.card-desc { font-size:.94rem; line-height:1.65; color:var(--mute); flex:1; margin-bottom:18px; }
.card-meta { font-family:"Cormorant SC",serif; font-size:.58rem; letter-spacing:.12em; color:var(--mute); border-top:1px solid var(--rule); padding-top:12px; margin-bottom:12px; display:flex; flex-direction:column; gap:4px; }
.card-meta strong { color:var(--char); }
.card-link { font-family:"Cormorant SC",serif; font-size:.64rem; letter-spacing:.16em; color:var(--red); text-decoration:none; display:flex; align-items:center; gap:6px; transition:gap .2s; }
.card-link:hover { gap:10px; }
.card-link::after { content:"→"; }

/* ── S4: ILIAD SPOTLIGHT ── */
.iliad-spot { background:var(--ink); display:grid; grid-template-columns:380px 1fr; min-height:680px; }
.iliad-book { display:flex; align-items:stretch; border-right:1px solid rgba(255,255,255,.06); }
.iliad-book svg { width:100%; height:100%; display:block; }
.iliad-content { padding:42px 88px 44px; display:flex; flex-direction:column; justify-content:center; }
.iliad-tag { font-family:"Cormorant SC",serif; font-size:.65rem; letter-spacing:.26em; color:var(--gold); margin-bottom:20px; }
.iliad-hed { font-family:"Cormorant Garamond",serif; font-size:84px; font-weight:400; line-height:.95; color:var(--warm); margin-bottom:20px; }
.iliad-hed em { font-style:italic; color:var(--gold2); }
.iliad-sub { font-family:"Cormorant SC",serif; font-size:.66rem; letter-spacing:.15em; color:rgba(240,235,224,.4); margin-bottom:24px; }
.iliad-desc { font-size:1.12rem; line-height:1.78; color:rgba(240,235,224,.75); max-width:56ch; margin-bottom:32px; }
.iliad-desc em { color:var(--gold2); font-style:italic; }
.iliad-grid { display:flex; gap:48px; margin-bottom:36px; }
.iliad-det .lbl { font-family:"Cormorant SC",serif; font-size:.58rem; letter-spacing:.2em; color:var(--gold); display:block; margin-bottom:4px; }
.iliad-det .val { font-family:"Cormorant Garamond",serif; font-size:1.08rem; color:var(--warm); }
.iliad-btns { display:flex; gap:14px; margin-bottom:36px; }
.btn-gold { font-family:"Cormorant SC",serif; font-size:.72rem; letter-spacing:.14em; background:var(--gold); color:var(--ink); padding:13px 28px; text-decoration:none; transition:background .2s; display:inline-block; }
.btn-gold:hover { background:var(--gold2); }
.btn-ghost { font-family:"Cormorant SC",serif; font-size:.72rem; letter-spacing:.14em; border:1px solid rgba(240,235,224,.25); color:var(--warm); padding:13px 28px; text-decoration:none; transition:border-color .2s; display:inline-block; }
.btn-ghost:hover { border-color:rgba(240,235,224,.7); }

/* Accordions */
.accords { border-top:1px solid rgba(255,255,255,.1); }
.accord { border-bottom:1px solid rgba(255,255,255,.1); }
.accord-btn {
  width:100%; display:flex; align-items:center; justify-content:space-between;
  padding:16px 0; background:none; border:none; cursor:pointer;
  color:rgba(240,235,224,.65); font-family:"Cormorant SC",serif; font-size:.7rem; letter-spacing:.14em; text-align:left;
  transition:color .2s;
}
.accord-btn:hover { color:var(--warm); }
.accord-icon { font-size:1rem; color:var(--gold); transition:transform .25s; flex-shrink:0; margin-left:12px; }
.accord.open .accord-icon { transform:rotate(45deg); }
.accord-body { max-height:0; overflow:hidden; transition:max-height .32s ease; }
.accord.open .accord-body { max-height:500px; }
.accord-body-inner { padding:0 0 16px; font-size:.98rem; line-height:1.75; color:rgba(240,235,224,.6); }
.accord-body-inner ul { padding-left:1.4em; }
.accord-body-inner li { margin-bottom:6px; }

/* ── S5: QUOTE ── */
.quote-band { background:var(--red); padding:80px 180px; text-align:center; }
.quote-t { font-family:"Cormorant Garamond",serif; font-size:2.75rem; font-style:italic; font-weight:300; line-height:1.38; color:var(--warm); margin-bottom:20px; }
.quote-a { font-family:"Cormorant SC",serif; font-size:.68rem; letter-spacing:.22em; color:rgba(240,235,224,.6); }

/* ── S6: ENROLL ── */
.enroll { display:grid; grid-template-columns:1fr 1fr; background:var(--char); }
.enroll-l { padding:100px 80px; border-right:1px solid rgba(255,255,255,.08); }
.enroll-r { padding:100px 80px; }
.enroll-tag { font-family:"Cormorant SC",serif; font-size:.66rem; letter-spacing:.26em; color:var(--gold); margin-bottom:20px; display:flex; align-items:center; gap:12px; }
.enroll-tag::after { content:""; display:block; width:36px; height:1px; background:var(--gold); }
.enroll-hed { font-family:"Cormorant Garamond",serif; font-size:64px; font-weight:400; line-height:1.05; color:var(--cream); margin-bottom:24px; }
.enroll-hed em { font-style:italic; color:var(--gold2); }
.enroll-body { font-size:1.1rem; line-height:1.78; color:rgba(240,235,224,.65); max-width:42ch; margin-bottom:36px; }
.enroll-price { font-family:"Cormorant Garamond",serif; font-size:96px; font-weight:300; color:var(--gold); line-height:1; }
.enroll-note { font-family:"Cormorant SC",serif; font-size:.62rem; letter-spacing:.16em; color:rgba(240,235,224,.3); display:block; margin:6px 0 28px; }
.pay-row { display:flex; gap:10px; }
.ppill { font-family:"Cormorant SC",serif; font-size:.62rem; letter-spacing:.16em; color:rgba(240,235,224,.5); border:1px solid rgba(240,235,224,.16); padding:6px 16px; }
.enroll-r-hed { font-family:"Cormorant Garamond",serif; font-size:48px; font-weight:400; line-height:1.1; color:var(--cream); margin-bottom:20px; }
.enroll-r-body { font-size:1.08rem; line-height:1.78; color:rgba(240,235,224,.65); margin-bottom:16px; }
.enroll-r-body a { color:var(--gold2); border-bottom:1px solid rgba(228,180,64,.3); text-decoration:none; }
.enroll-r-body a:hover { border-color:var(--gold2); }

/* ── FOOTER ── */
footer {
  background:var(--ink); padding:30px 56px;
  display:flex; align-items:center; justify-content:space-between;
  border-top:1px solid rgba(255,255,255,.05);
}
.foot-brand { font-family:"Cormorant SC",serif; font-size:.68rem; letter-spacing:.14em; color:rgba(240,235,224,.35); }
.foot-links { display:flex; gap:32px; list-style:none; }
.foot-links a { font-family:"Cormorant SC",serif; font-size:.63rem; letter-spacing:.13em; color:rgba(240,235,224,.28); text-decoration:none; transition:color .2s; }
.foot-links a:hover { color:rgba(240,235,224,.7); }

/* ── BRAND SYMBOL ADDITIONS ── */

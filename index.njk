---
title: "Nick Rosado · Enlightenment Educator"
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site.title }}</title>
<meta name="description" content="{{ site.description }}">
<meta property="og:type" content="website">
<meta property="og:url" content="https://enlightenmenteducator.com/">
<meta property="og:site_name" content="{{ site.brand }}">
<meta property="og:title" content="{{ site.title }}">
<meta property="og:description" content="{{ site.description }}">
<meta property="og:image" content="https://enlightenmenteducator.com{{ site.social_image }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ site.title }}">
<meta name="twitter:description" content="{{ site.description }}">
<meta name="twitter:image" content="https://enlightenmenteducator.com{{ site.social_image }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=Cormorant+SC:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
:root{--cream:#f0ebe0;--warm:#faf7f2;--ink:#16110d;--char:#2b2118;--gold:#c49220;--gold2:#e4b440;--red:#891b1b;--mute:#7a6e60;--rule:#d0c4b0}*{box-sizing:border-box;margin:0;padding:0}html{font-size:16px;scroll-behavior:smooth}body{background:var(--cream);color:var(--ink);font-family:"EB Garamond",Georgia,serif;overflow-x:hidden}a{color:inherit}nav{position:fixed;top:0;left:0;right:0;z-index:20;height:78px;display:flex;align-items:center;justify-content:space-between;padding:0 68px;background:rgba(240,235,224,.97);backdrop-filter:blur(8px);border-bottom:1px solid var(--rule)}.nav-logo{display:flex;align-items:center;gap:20px;font-family:"Cormorant SC",serif;font-size:1.55rem;letter-spacing:.26em;color:var(--char);text-decoration:none}.nav-mark{width:68px;height:68px;object-fit:contain}.nav-links{display:flex;gap:48px;list-style:none}.nav-links a,.nav-cta a{font-family:"Cormorant SC",serif;font-size:.88rem;letter-spacing:.18em;color:var(--mute);text-decoration:none}.nav-links a:hover{color:var(--red)}.nav-cta a{background:var(--ink);color:var(--warm);padding:14px 30px}.nav-cta a:hover{background:var(--red)}.hero{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;padding-top:78px}.hero-l{padding:90px 82px 86px;display:flex;flex-direction:column;justify-content:center;background:var(--cream)}.hero-eyebrow,.sec-tag,.featured-tag,.enroll-tag{font-family:"Cormorant SC",serif;font-size:1.18rem;letter-spacing:.28em;color:var(--gold);margin-bottom:24px}.hero-hed{font-family:"Cormorant Garamond",serif;font-size:98px;font-weight:400;line-height:1.02;margin-bottom:34px}.hero-hed em,.about-hed em,.courses-hed em,.enroll-hed em{font-style:italic;color:var(--red)}.hero-sub{font-size:1.34rem;line-height:1.8;color:var(--char);max-width:46ch;margin-bottom:54px}.btns{display:flex;gap:14px;flex-wrap:wrap}.btn-dark,.btn-outline,.btn-get,.btn-gold,.btn-ghost{font-family:"Cormorant SC",serif;font-size:.88rem;letter-spacing:.17em;padding:17px 36px;text-decoration:none;display:inline-block}.btn-dark,.btn-get{background:var(--ink);color:var(--warm)}.btn-dark:hover,.btn-get:hover{background:var(--red)}.btn-outline{border:1px solid var(--rule);color:var(--ink)}.hero-r{display:grid;grid-template-columns:1fr 1fr;grid-template-rows:1fr 1fr;overflow:hidden}.poet-cell{position:relative;overflow:hidden}.poet-cell img{width:100%;height:100%;object-fit:cover;object-position:center 20%;display:block;filter:grayscale(15%) brightness(.9);transition:.45s}.poet-cell:hover img{transform:scale(1.05);filter:grayscale(0) brightness(1)}.poet-label{position:absolute;bottom:0;left:0;right:0;padding:40px 18px 14px;background:linear-gradient(to top,rgba(22,17,13,.75),transparent);font-family:"Cormorant SC",serif;font-size:.9rem;letter-spacing:.2em;color:rgba(240,235,224,.9)}.about{display:grid;grid-template-columns:1fr 1fr;min-height:680px;background:var(--warm)}.about-l{padding:86px 82px 92px;display:flex;flex-direction:column;justify-content:center;border-right:1px solid var(--rule)}.about-seal{width:220px;height:220px;object-fit:contain;margin-bottom:40px}.sec-tag{display:flex;align-items:center;gap:12px}.sec-tag:after{content:"";width:36px;height:1px;background:var(--gold)}.about-hed{font-family:"Cormorant Garamond",serif;font-size:86px;font-weight:400;line-height:1.03;margin-bottom:36px}.about-body{font-size:1.34rem;line-height:1.88;color:var(--char);max-width:50ch;margin-bottom:22px}.about-pull{border-left:3px solid var(--gold);padding-left:22px;margin:34px 0;font-family:"Cormorant Garamond",serif;font-size:1.62rem;font-style:italic;line-height:1.58;color:var(--char)}.about-r{min-height:680px;overflow:hidden}.about-r img{width:100%;height:100%;object-fit:cover;object-position:center 15%;display:block}.courses{padding:92px 60px 100px;background:var(--cream)}.courses-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:56px}.courses-hed{font-family:"Cormorant Garamond",serif;font-size:76px;font-weight:400;line-height:1}.courses-grid{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid var(--rule)}.card{border-right:1px solid var(--rule);background:var(--warm);display:flex;flex-direction:column}.card:last-child{border-right:none}.card-img-wrap{position:relative;overflow:hidden;aspect-ratio:3/4}.card-img-wrap img{width:100%;height:100%;object-fit:cover;display:block;transition:.45s}.card:hover img{transform:scale(1.04)}.badge{position:absolute;top:14px;left:14px;font-family:"Cormorant SC",serif;font-size:.9rem;letter-spacing:.2em;padding:5px 10px;color:var(--warm);background:var(--red)}.badge-blue{background:#243142}.badge-dk{background:#3a3028}.card-body{padding:24px 24px 28px;display:flex;flex:1;flex-direction:column;border-top:1px solid var(--rule)}.card-poet{font-family:"Cormorant SC",serif;font-size:.95rem;letter-spacing:.18em;color:var(--gold);margin-bottom:8px}.card-title{font-family:"Cormorant Garamond",serif;font-size:1.55rem;font-weight:400;line-height:1.1;margin-bottom:10px}.card-desc{font-size:.98rem;line-height:1.65;color:var(--mute);flex:1;margin-bottom:18px}.card-meta{font-family:"Cormorant SC",serif;font-size:.78rem;letter-spacing:.12em;color:var(--mute);border-top:1px solid var(--rule);padding-top:12px;margin-bottom:12px;display:flex;flex-direction:column;gap:4px}.card-meta strong{color:var(--char)}.card-link{font-family:"Cormorant SC",serif;font-size:.78rem;letter-spacing:.16em;color:var(--red);text-decoration:none}.card-link:after{content:" →"}.featured{--course-accent:{{ featured.colors.accent }};--course-accent-dark:{{ featured.colors.accent_dark }};--course-accent-soft:{{ featured.colors.accent_soft }};--course-highlight:{{ featured.colors.highlight }};background:var(--ink);display:grid;grid-template-columns:360px 1fr;color:var(--warm)}.featured-art{position:relative;overflow:hidden;min-height:650px;background:var(--course-accent-dark);border-right:1px solid rgba(255,255,255,.08)}.featured-art img{width:100%;height:100%;min-height:650px;object-fit:cover;object-position:58% center;filter:grayscale(8%) brightness(.82) contrast(1.08);display:block}.featured-art:after{content:"";position:absolute;inset:0;background:linear-gradient(to top,rgba(22,17,13,.8),rgba(22,17,13,.22) 42%,rgba(22,17,13,.1)),linear-gradient(to right,var(--course-accent-soft),transparent 58%)}.featured-art-caption{position:absolute;left:38px;bottom:36px;z-index:2;font-family:"Cormorant SC",serif;font-size:1.28rem;letter-spacing:.24em;color:rgba(250,247,242,.86)}.featured-content{padding:68px 88px 72px;display:grid;grid-template-columns:minmax(340px,.74fr) minmax(520px,1fr);column-gap:78px;align-content:center}.featured-tag{grid-column:1/-1;color:var(--course-highlight)}.featured-hed{grid-column:1;font-family:"Cormorant Garamond",serif;font-size:88px;font-weight:400;line-height:.95;margin-bottom:22px}.featured-hed em{font-style:italic;color:var(--course-highlight)}.featured-sub{grid-column:1;font-family:"Cormorant SC",serif;font-size:.96rem;letter-spacing:.2em;line-height:1.6;color:rgba(240,235,224,.55);margin-bottom:20px}.book-note{grid-column:1;font-family:"Cormorant SC",serif;font-size:.82rem;letter-spacing:.18em;line-height:1.65;color:rgba(240,235,224,.38)}.featured-desc{grid-column:2;grid-row:2/span 3;font-size:1.2rem;line-height:1.8;color:rgba(240,235,224,.75);margin:4px 0 30px}.featured-desc em{color:var(--course-highlight)}.detail-grid{grid-column:1/-1;display:grid;grid-template-columns:repeat(4,1fr);margin:42px 0 30px;border-top:1px solid rgba(240,235,224,.12);border-bottom:1px solid rgba(240,235,224,.12)}.det{padding:22px 28px 20px;border-right:1px solid rgba(240,235,224,.1)}.det:last-child{border-right:none}.det .lbl{font-family:"Cormorant SC",serif;font-size:.94rem;letter-spacing:.22em;color:var(--course-highlight);display:block;margin-bottom:8px}.det .val{font-family:"Cormorant Garamond",serif;font-size:1.28rem;color:var(--warm)}.featured .btns{grid-column:1/-1;margin-bottom:44px}.btn-gold{background:var(--course-accent);color:var(--warm)}.btn-ghost{border:1px solid rgba(240,235,224,.25);color:var(--warm)}.accords{grid-column:1/-1;border-top:1px solid rgba(240,235,224,.18)}.accord{border-bottom:1px solid rgba(240,235,224,.15);padding:24px 0}.accord-label{display:flex;gap:24px;align-items:baseline}.accord-kicker{min-width:154px;font-family:"Cormorant SC",serif;font-size:.9rem;letter-spacing:.22em;color:var(--course-highlight)}.accord-title{font-family:"Cormorant Garamond",serif;font-size:1.55rem}.accord-body{padding-left:178px;margin-top:8px;color:rgba(240,235,224,.62);font-size:1.05rem;line-height:1.75}.quote-band{background:{{ featured.colors.accent }};padding:92px 180px;text-align:center}.quote-t{font-family:"Cormorant Garamond",serif;font-size:3.25rem;font-style:italic;font-weight:300;line-height:1.35;color:var(--warm);margin-bottom:20px}.quote-a{font-family:"Cormorant SC",serif;font-size:.84rem;letter-spacing:.25em;color:rgba(240,235,224,.65)}.enroll{display:grid;grid-template-columns:1fr 1fr;background:var(--char)}.enroll-l,.enroll-r{padding:100px 80px}.enroll-l{border-right:1px solid rgba(255,255,255,.08)}.enroll-hed{font-family:"Cormorant Garamond",serif;font-size:64px;font-weight:400;line-height:1.05;color:var(--cream);margin-bottom:24px}.enroll-body,.enroll-r-body{font-size:1.1rem;line-height:1.78;color:rgba(240,235,224,.65);margin-bottom:16px}.enroll-price{font-family:"Cormorant Garamond",serif;font-size:96px;font-weight:300;color:var(--gold);line-height:1}.enroll-note,.ppill{font-family:"Cormorant SC",serif;font-size:.95rem;letter-spacing:.18em;color:rgba(240,235,224,.5)}.enroll-note{display:block;margin:6px 0 28px}.pay-row{display:flex;gap:10px;flex-wrap:wrap}.ppill{border:1px solid rgba(240,235,224,.16);padding:6px 16px}.enroll-r-hed{font-family:"Cormorant Garamond",serif;font-size:48px;font-weight:400;line-height:1.1;color:var(--cream);margin-bottom:20px}.enroll-r-body a{color:var(--gold2);text-decoration:none;border-bottom:1px solid rgba(228,180,64,.3)}footer{background:var(--ink);padding:30px 56px;display:grid;grid-template-columns:auto 1fr auto;gap:28px;align-items:start;border-top:1px solid rgba(255,255,255,.05)}.footer-mark{width:64px;height:64px;object-fit:contain;opacity:.7}.foot-brand{font-family:"Cormorant SC",serif;font-size:.95rem;letter-spacing:.18em;color:rgba(240,235,224,.35)}.foot-links{display:flex;gap:32px;list-style:none}.foot-links a{font-family:"Cormorant SC",serif;font-size:.95rem;letter-spacing:.18em;color:rgba(240,235,224,.35);text-decoration:none}@media(max-width:900px){nav{height:66px;padding:0 18px}.nav-logo{font-size:.92rem;gap:10px;letter-spacing:.18em}.nav-mark{width:48px;height:48px}.nav-links{display:none}.nav-cta a{font-size:.72rem;padding:10px 14px}.hero{grid-template-columns:1fr;padding-top:66px;min-height:0}.hero-l{padding:58px 26px 44px}.hero-hed{font-size:58px}.hero-sub{font-size:1.16rem}.hero-r{height:72vh;min-height:520px}.about,.featured,.enroll{grid-template-columns:1fr}.about-l{padding:56px 26px}.about-seal{width:140px;height:140px}.about-hed,.courses-hed{font-size:54px}.about-r{min-height:520px}.courses{padding:58px 18px}.courses-header{display:block}.courses-grid{grid-template-columns:1fr}.card{border-right:none;border-bottom:1px solid var(--rule)}.featured-art,.featured-art img{min-height:520px}.featured-content{padding:56px 24px;display:block}.featured-hed{font-size:58px}.featured-desc{font-size:1.1rem;margin-top:24px}.detail-grid{grid-template-columns:1fr 1fr}.accord-body{padding-left:0}.quote-band{padding:62px 24px}.quote-t{font-size:2.25rem}.enroll-l,.enroll-r{padding:62px 26px}.enroll-l{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}footer{grid-template-columns:1fr;text-align:center}.foot-links{justify-content:center;flex-wrap:wrap}.footer-mark{margin:auto}}
</style>
</head>
<body>
<nav>
  <a class="nav-logo" href="/"><img class="nav-mark" src="/EE_symbol_gold_transparent.png" alt="">{{ site.brand }}</a>
  <ul class="nav-links"><li><a href="#courses">Courses</a></li><li><a href="#featured">Featured</a></li><li><a href="#about">About</a></li><li><a href="/youtube/">YouTube</a></li></ul>
  <div class="nav-cta"><a href="#enroll">Enroll</a></div>
</nav>

<section class="hero" id="top">
  <div class="hero-l">
    <div class="hero-eyebrow">{{ hero.eyebrow }}</div>
    <h1 class="hero-hed">{{ hero.heading_prefix }} <em>{{ hero.heading_emphasis }}</em> {{ hero.heading_suffix }}</h1>
    <p class="hero-sub">{{ hero.subtitle }}</p>
    <div class="btns"><a class="btn-dark" href="{{ hero.primary_link }}">{{ hero.primary_label }}</a><a class="btn-outline" href="{{ hero.secondary_link }}">{{ hero.secondary_label }}</a></div>
  </div>
  <div class="hero-r">
    {% for item in hero.authors %}<div class="poet-cell"><img src="{{ item.image }}" alt="{{ item.alt }}"><div class="poet-label">{{ item.label }}</div></div>{% endfor %}
  </div>
</section>

<section class="about" id="about">
  <div class="about-l">
    <img class="about-seal" src="{{ about.seal }}" alt="">
    <div class="sec-tag">{{ about.eyebrow }}</div>
    <h2 class="about-hed">{{ about.heading_prefix }} <em>{{ about.heading_emphasis }}</em></h2>
    <p class="about-body">{{ about.body_1 }}</p>
    <p class="about-body">{{ about.body_2 }}</p>
    <div class="about-pull">{{ about.pull_quote }}</div>
    <p><a class="btn-get" href="{{ about.button_link }}">{{ about.button_label }}</a></p>
  </div>
  <div class="about-r"><img src="{{ about.photo }}" alt="{{ about.photo_alt }}"></div>
</section>

<section class="courses" id="courses">
  <div class="courses-header"><div><div class="sec-tag">COURSES</div><h2 class="courses-hed">The great <em>epics</em></h2></div></div>
  <div class="courses-grid">
    {% set courseList = [courses["iliad"], courses["divine-comedy"], courses["aeneid"], courses["paradise-lost"]] %}
{% for c in courseList %}
    <article class="card">
      <div class="card-img-wrap"><img src="{{ course.image }}" alt="{{ course.image_alt }}"><span class="badge {{ course.badge_class }}">{{ course.badge }}</span></div>
      <div class="card-body"><div class="card-poet">{{ course.poet }}</div><h3 class="card-title">{{ course.title }}</h3><p class="card-desc">{{ course.description }}</p><div class="card-meta">{% for item in course.meta %}<span><strong>{{ item.label }}:</strong> {{ item.value }}</span>{% endfor %}</div><a class="card-link" href="{{ course.link_url }}">{{ course.link_label }}</a></div>
    </article>
    {% endfor %}
  </div>
</section>

<section class="featured" id="featured">
  <div class="featured-art"><img src="{{ featured.art_image }}" alt="{{ featured.art_alt }}"><div class="featured-art-caption">{{ featured.art_caption }}</div></div>
  <div class="featured-content">
    <div class="featured-tag">{{ featured.tag }}</div>
    <h2 class="featured-hed">{{ featured.title_prefix }} <em>{{ featured.title_emphasis }}</em></h2>
    <div class="featured-sub">{{ featured.subtitle }}</div>
    <div class="book-note">{{ featured.book_note }}</div>
    <div class="featured-desc">{{ featured.description | markdownish | safe }}</div>
    <div class="detail-grid">{% for item in featured.details %}<div class="det"><span class="lbl">{{ item.label }}</span><span class="val">{{ item.value }}</span></div>{% endfor %}</div>
    <div class="btns"><a class="btn-gold" href="{{ featured.primary_link }}">{{ featured.primary_label }}</a><a class="btn-ghost" href="{{ featured.secondary_link }}">{{ featured.secondary_label }}</a></div>
    <div class="accords">{% for item in featured.syllabus %}<div class="accord"><div class="accord-label"><span class="accord-kicker">{{ item.kicker }}</span><span class="accord-title">{{ item.title }}</span></div><div class="accord-body">{{ item.content }}</div></div>{% endfor %}</div>
  </div>
</section>

<section class="quote-band"><p class="quote-t">“{{ featured.quote_text }}”</p><p class="quote-a">{{ featured.quote_attribution }}</p></section>

<section class="enroll" id="enroll">
  <div class="enroll-l"><div class="enroll-tag">{{ enroll.tag }}</div><h2 class="enroll-hed">{{ enroll.heading_prefix }} <em>{{ enroll.heading_emphasis }}</em></h2><p class="enroll-body">{{ enroll.body }}</p><div class="enroll-price">{{ enroll.price }}</div><span class="enroll-note">{{ enroll.price_note }}</span><div class="pay-row">{% for method in enroll.payment_methods %}<span class="ppill">{{ method }}</span>{% endfor %}</div></div>
  <div class="enroll-r"><h3 class="enroll-r-hed">{{ enroll.right_heading }}</h3><p class="enroll-r-body">{{ enroll.right_body_1 }}</p><p class="enroll-r-body">{{ enroll.right_body_2 | safe }}</p></div>
</section>

<footer><img class="footer-mark" src="/EE_symbol_gold_transparent.png" alt=""><div class="foot-brand">{{ enroll.footer_brand }}</div><ul class="foot-links">{% for link in enroll.footer_links %}<li><a href="{{ link.url }}">{{ link.label }}</a></li>{% endfor %}</ul></footer>
</body>
</html>

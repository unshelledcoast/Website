<script>
function tog(btn) {
  const item = btn.closest(".accord");
  const wasOpen = item.classList.contains("open");
  document.querySelectorAll(".accord").forEach(a => a.classList.remove("open"));
  if (!wasOpen) item.classList.add("open");
}
</script>
